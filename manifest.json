{
  "manifest_version": 3,
  "name": "SafeInbox",
  "version": "1.0",
  "description": "Detect phishing emails",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeInbox Scanner"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}